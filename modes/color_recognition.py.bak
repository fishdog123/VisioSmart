import cv2
import numpy as np
import time
from collections import deque, Counter

from config import (
    COLOR_SAMPLE_SIZE, COLOR_SAMPLE_PERCENT, COLOR_SMOOTHING_FRAMES,
    COLOR_TTS_COOLDOWN, HEADLESS_MODE, tts_queue
)


class ColorRecognition:
    def __init__(self):
        # Palette defined in RGB; we reverse to BGR for OpenCV conversions.
        self.palette_rgb = {
            "Red": (255, 0, 0),
            "Orange": (255, 165, 0),
            "Yellow": (255, 255, 0),
            "Green": (0, 255, 0),
            "Blue": (0, 0, 255),
            # "Purple": (128, 0, 128),
            # "Pink": (255, 192, 203),
            # "Brown": (150, 75, 0),
            "Black": (0, 0, 0),
            "White": (255, 255, 255),
            "Gray": (128, 128, 128),
        }

        # Precompute Lab values (converted to standard CIE L*a*b*) for perceptual distance
        self.palette_lab = {}
        self.palette_bgr = {}
        for name, rgb in self.palette_rgb.items():
            # Build an RGB array for perceptual conversion, then store display BGR
            rgb_arr = np.uint8([[[rgb[0], rgb[1], rgb[2]]]])
            lab = cv2.cvtColor(rgb_arr, cv2.COLOR_RGB2LAB)[0, 0, :].astype(float)
            # Convert OpenCV Lab (L:0-255, a/b:0-255 with 128 offset) to standard CIE L*a*b*
            lab_std = np.array([lab[0] * (100.0 / 255.0), lab[1] - 128.0, lab[2] - 128.0], dtype=float)
            self.palette_lab[name] = lab_std
            # store display color in BGR order for OpenCV drawing
            self.palette_bgr[name] = (int(rgb[2]), int(rgb[1]), int(rgb[0]))

        self.buffer = deque(maxlen=(COLOR_SMOOTHING_FRAMES or 5))
        self.last_label = None
        self.last_spoken = 0.0

    def _compute_sample_box(self, frame):
        h, w = frame.shape[:2]
        if COLOR_SAMPLE_SIZE and COLOR_SAMPLE_SIZE > 0:
            size = int(COLOR_SAMPLE_SIZE)
        else:
            size = max(8, int(min(w, h) * (COLOR_SAMPLE_PERCENT or 0.05)))
        half = size // 2
        cx = w // 2
        cy = h // 2
        x1 = max(0, cx - half)
        x2 = min(w, cx + half)
        y1 = max(0, cy - half)
        y2 = min(h, cy + half)
        return x1, y1, x2, y2, cx, cy

    def _ciede2000(self, lab1, lab2):
        # CIEDE2000 implementation expects Lab in standard CIE ranges:
        # L in [0,100], a and b in [-128,127]
        L1, a1, b1 = float(lab1[0]), float(lab1[1]), float(lab1[2])
        L2, a2, b2 = float(lab2[0]), float(lab2[1]), float(lab2[2])
        import math
        C1 = math.hypot(a1, b1)
        C2 = math.hypot(a2, b2)
        C_bar = (C1 + C2) / 2.0
        G = 0.5 * (1 - math.sqrt((C_bar ** 7) / (C_bar ** 7 + 25 ** 7)))
        a1p = (1 + G) * a1
        a2p = (1 + G) * a2
        C1p = math.hypot(a1p, b1)
        C2p = math.hypot(a2p, b2)

        def _hp(a, b):
            if a == 0 and b == 0:
                return 0.0
            h = math.degrees(math.atan2(b, a))
            return h + 360.0 if h < 0 else h

        h1p = _hp(a1p, b1)
        h2p = _hp(a2p, b2)
        dLp = L2 - L1
        dCp = C2p - C1p
        if C1p * C2p == 0:
            dhp = 0.0
        else:
            dh = h2p - h1p
            if dh > 180:
                dh -= 360
            elif dh < -180:
                dh += 360
            dhp = dh
        dHp = 2.0 * math.sqrt(max(0.0, C1p * C2p)) * math.sin(math.radians(dhp) / 2.0)
        Lp_bar = (L1 + L2) / 2.0
        Cp_bar = (C1p + C2p) / 2.0
        if C1p * C2p == 0:
            hp_bar = h1p + h2p
        else:
            if abs(h1p - h2p) > 180.0:
                hp_bar = (h1p + h2p + 360.0) / 2.0 if (h1p + h2p) < 360.0 else (h1p + h2p - 360.0) / 2.0
            else:
                hp_bar = (h1p + h2p) / 2.0
        T = (1.0
             - 0.17 * math.cos(math.radians(hp_bar - 30.0))
             + 0.24 * math.cos(math.radians(2.0 * hp_bar))
             + 0.32 * math.cos(math.radians(3.0 * hp_bar + 6.0))
             - 0.20 * math.cos(math.radians(4.0 * hp_bar - 63.0)))
        delta_ro = 30.0 * math.exp(-((hp_bar - 275.0) / 25.0) ** 2)
        Rc = 2.0 * math.sqrt((Cp_bar ** 7) / (Cp_bar ** 7 + 25 ** 7))
        Sl = 1.0 + (0.015 * (Lp_bar - 50.0) ** 2) / math.sqrt(20.0 + (Lp_bar - 50.0) ** 2)
        Sc = 1.0 + 0.045 * Cp_bar
        Sh = 1.0 + 0.015 * Cp_bar * T
        Rt = -math.sin(math.radians(2.0 * delta_ro)) * Rc
        dE = math.sqrt(
            (dLp / Sl) ** 2 +
            (dCp / Sc) ** 2 +
            (dHp / Sh) ** 2 +
            Rt * (dCp / Sc) * (dHp / Sh)
        )
        return dE

    def _detect_label(self, frame):
        x1, y1, x2, y2, cx, cy = self._compute_sample_box(frame)
        region = frame[y1:y2, x1:x2]
        if region.size == 0:
            return "Unknown", (255, 255, 255), (x1, y1, x2, y2, cx, cy)

        # Convert BGR region -> RGB -> Lab (OpenCV), then to standard Lab for ΔE00
        rgb_region = cv2.cvtColor(region, cv2.COLOR_BGR2RGB)
        lab_cv = cv2.cvtColor(rgb_region, cv2.COLOR_RGB2LAB)
        mean_lab_cv = lab_cv.reshape(-1, 3).mean(axis=0)
        mean_lab = np.array([mean_lab_cv[0] * (100.0 / 255.0), mean_lab_cv[1] - 128.0, mean_lab_cv[2] - 128.0], dtype=float)

        # Nearest palette by CIEDE2000 distance (ΔE00)
        best = None
        best_dist = float("inf")
        for name, pal_lab in self.palette_lab.items():
            dist = self._ciede2000(mean_lab, pal_lab)
            if dist < best_dist:
                best_dist = dist
                best = name

        display_bgr = self.palette_bgr.get(best, (255, 255, 255))
        return best, display_bgr, (x1, y1, x2, y2, cx, cy)

    def process(self, frame):
        label, display_bgr, box = self._detect_label(frame)
        x1, y1, x2, y2, cx, cy = box

        self.buffer.append(label)
        try:
            modal_label = Counter(self.buffer).most_common(1)[0][0]
        except Exception:
            modal_label = label

        now = time.time()
        if modal_label != self.last_label:
            if now - self.last_spoken > (COLOR_TTS_COOLDOWN or 6.0):
                tts_queue.put(f"Color: {modal_label}")
                self.last_spoken = now
            self.last_label = modal_label

        if not HEADLESS_MODE:
            # Draw sample region and label
            cv2.rectangle(frame, (x1, y1), (x2, y2), display_bgr, 2)
            cv2.circle(frame, (cx, cy), 3, (25, 25, 25), 2)

            text = modal_label
            (tw, th), _ = cv2.getTextSize(text, cv2.FONT_HERSHEY_SIMPLEX, 0.8, 2)
            tx = x1
            ty = max(10, y1 - 10)
            cv2.rectangle(frame, (tx, ty - th - 6), (tx + tw + 6, ty + 4), (255, 255, 255), -1)
            cv2.putText(frame, text, (tx + 3, ty - 2), cv2.FONT_HERSHEY_SIMPLEX, 0.8, display_bgr, 2, cv2.LINE_AA)

        return frame

    def summarize(self, frame):
        label, _, _ = self._detect_label(frame)
        return f"Dominant color: {label}"

    def reset(self):
        self.buffer.clear()
        self.last_label = None
        self.last_spoken = 0.0
